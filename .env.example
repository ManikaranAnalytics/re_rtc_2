# ─────────────────────────────────────────────────────────────────────────────
# RE-RTC Dispatch Optimizer — Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Port the FastAPI server listens on (default 8000)
PORT=8000

# Number of uvicorn worker processes (default 2; set to CPU count for prod)
WEB_CONCURRENCY=2

# CORS allowed origins. Use "*" for dev. In production, set to your domain:
# e.g. ALLOWED_ORIGINS=https://rtc.yourdomain.com
ALLOWED_ORIGINS=*
